        }

        // አንዴ ጠቅ = ወደ መጨረሻ ዘልሎ መሄድ
        function jumpToBottom() {
            stopScroll();
            window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
            showToast('⏬ ወደ ገጹ መጨረሻ ዘሏል');
        }

        function cycleScrollSpeed() {
            if (scrollSpeed === 'normal') scrollSpeed = 'fast';
            else if (scrollSpeed === 'fast') scrollSpeed = 'slow';
            else scrollSpeed = 'normal';
            localStorage.setItem('TECH_SCROLL_ARROW_SPEED', scrollSpeed);
            updateMiniSpeedIndicators();
            const labels = { 'slow': 'ስሎው (0.5x)', 'normal': 'መደበኛ (1x)', 'fast': 'ፋስት (3x)' };
            showToast('⚡ የስክሮል ፍጥነት: ' + labels[scrollSpeed]);
        }

        // ድርብ ጠቅ ለፍጥነት መቀየሪያ
        document.addEventListener('DOMContentLoaded', function() {
            updateMiniSpeedIndicators();

            const upBtn = document.getElementById('btnScrollUp');
            const downBtn = document.getElementById('btnScrollDown');
            if (upBtn) {
                upBtn.addEventListener('dblclick', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    stopScroll();
                    cycleScrollSpeed();
                });
            }
            if (downBtn) {
                downBtn.addEventListener('dblclick', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    stopScroll();
                    cycleScrollSpeed();
                });
            }
        });

        // ==================== ፔጂኔሽን ተግባራት ====================
        function updatePaginationUI() {
            document.getElementById('pageInfo').textContent = `ገጽ ${currentPage} / ${totalPages}`;
            document.getElementById('currentPageLabel').textContent = currentPage;

            document.getElementById('btnFirst').disabled = currentPage <= 1;
            document.getElementById('btnPrev').disabled = currentPage <= 1;
            document.getElementById('btnNext').disabled = currentPage >= totalPages;
            document.getElementById('btnLast').disabled = currentPage >= totalPages;

            document.getElementById('quickJumpInput').max = totalPages;
            document.getElementById('quickJumpInput').value = '';
