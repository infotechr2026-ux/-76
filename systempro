        function checkLockout() { let now = Math.floor(Date.now() / 1000); if (lockoutUntil > now) { showLockout(lockoutUntil -
                now); return true; } if (loginAttempts >= MAX_LOGIN_ATTEMPTS) { loginAttempts = 0;
                localStorage.setItem('TECH_LOGIN_ATTEMPTS', '0');
                localStorage.removeItem('TECH_LOCKOUT_UNTIL');
                lockoutUntil = 0; } return false; }

        function showLockout(seconds) { document.getElementById('lockoutOverlay').style.display = 'flex'; let timer = document
                .getElementById('lockoutTimer');
            timer.innerText = seconds; let iv = setInterval(() => { seconds--;
                timer.innerText = seconds; if (seconds <= 0) { clearInterval(iv);
                    document.getElementById('lockoutOverlay').style.display = 'none';
                    loginAttempts = 0;
                    localStorage.setItem('TECH_LOGIN_ATTEMPTS', '0');
                    lockoutUntil = 0; } }, 1000); }

        function login() { if (localStorage.getItem('TECH_DEVICE_DESTROYED')) { document.getElementById('deviceDestroyOverlay')
                .style.display = 'flex'; return; } if (checkLockout()) return; let uN = sanitizeInput(document.getElementById('u')
                .value.toLowerCase()); let uP = document.getElementById('p').value; if (!uN || !uP) { alert(
                "የተጠቃሚ ስም እና የይለፍ ቃል ያስፈልጋል"); return; }
            initializeUsers(); let user = users.find(x => x.name === uN); if (!user) { loginAttempts++;
                localStorage.setItem('TECH_LOGIN_ATTEMPTS', String(loginAttempts));
                logLogin(uN, 'failed'); if (loginAttempts >= MAX_LOGIN_ATTEMPTS) { lockoutUntil = Math.floor(Date.now() /
                        1000) + LOCKOUT_DURATION;
                    localStorage.setItem('TECH_LOCKOUT_UNTIL', String(lockoutUntil));
                    showLockout(LOCKOUT_DURATION); } else alert('የተሳሳተ የተጠቃሚ ስም ወይም የይለፍ ቃል'); return; } if (user.status ===
                'blocked') { if (!handlePreLoginCheck(uN)) return;
                alert('መለያዎ ታግዷል። እባክዎ አስተዳዳሪዎን ያግኙ።'); return; } if (!verifyPassword(uP, user.passHash)) { loginAttempts++;
                localStorage.setItem('TECH_LOGIN_ATTEMPTS', String(loginAttempts));
                logLogin(uN, 'failed');
                alert('የተሳሳተ የይለፍ ቃል'); return; }
            if (uN === 'admin' && isAdminAlreadyLoggedIn()) {
                pendingConflictUsername = uN;
                pendingConflictPassword = uP;
                document.getElementById('adminConflictOverlay').style.display = 'flex';
                document.getElementById('secretVerificationSection').style.display = 'none';
                document.getElementById('secretVerificationInput').value = '';
                document.getElementById('secretError').style.display = 'none';
                document.getElementById('conflictYesBtn').style.display = 'inline-flex';
                addAuditEntry('ADMIN_CONFLICT_DETECTED', 'ሁለተኛ አድሚን ለመግባት ሞክሯል');
                return;
            }
            proceedWithLogin(uN, user); }

        function showSecretVerification() {
            document.getElementById('secretVerificationSection').style.display = 'block';
            document.getElementById('conflictYesBtn').style.display = 'none';
            document.getElementById('secretVerificationInput').focus();
        }

        function cancelAdminConflict() {
            document.getElementById('adminConflictOverlay').style.display = 'none';
            pendingConflictUsername = null;
            pendingConflictPassword = null;
            document.getElementById('secretVerificationInput').value = '';
            document.getElementById('secretError').style.display = 'none';
            addAuditEntry('ADMIN_CONFLICT_CANCELLED', 'አድሚን ግጭት ተሰርዟል');
        }

        function verifySecretAndLogin() {
            let secretInput = document.getElementById('secretVerificationInput').value;
            if (secretInput === ADMIN_SECRET_OVERRIDE_KEY) {
                activeSessions = activeSessions.filter(s => s.username !== 'admin' || s.logoutTime);
                localStorage.setItem('TECH_ACTIVE_SESSIONS', JSON.stringify(activeSessions));
                document.getElementById('adminConflictOverlay').style.display = 'none';
                document.getElementById('secretVerificationInput').value = '';
                document.getElementById('secretError').style.display = 'none';
                addAuditEntry('ADMIN_OVERRIDE_SUCCESS', 'አድሚን በማረጋገጫ ቁልፍ ቀዳሚውን አስወግዶ ገብቷል');
                showToast('✅ አድሚን ተረጋግጦ ገብቷል');
                let user = users.find(x => x.name === pendingConflictUsername);
                proceedWithLogin(pendingConflictUsername, user);
                pendingConflictUsername = null;
                pendingConflictPassword = null;
            } else {
                document.getElementById('secretError').style.display = 'block';
                document.getElementById('secretVerificationInput').value = '';
                document.getElementById('secretVerificationInput').classList.add('error');
                setTimeout(() => document.getElementById('secretVerificationInput').classList.remove('error'), 600);
                addAuditEntry('ADMIN_OVERRIDE_FAILED', 'የተሳሳተ የማረጋገጫ ቁልፍ ሙከራ');
                loginAttempts++;
                localStorage.setItem('TECH_LOGIN_ATTEMPTS', String(loginAttempts));
                if (loginAttempts >= MAX_LOGIN_ATTEMPTS) {
                    document.getElementById('adminConflictOverlay').style.display = 'none';
                    lockoutUntil = Math.floor(Date.now() / 1000) + LOCKOUT_DURATION;
                    localStorage.setItem('TECH_LOCKOUT_UNTIL', String(lockoutUntil));
                    showLockout(LOCKOUT_DURATION);
                    pendingConflictUsername = null;
                    pendingConflictPassword = null;
                }
            }
        }

        function proceedWithLogin(uN, user) {
            loginAttempts = 0;
            localStorage.setItem('TECH_LOGIN_ATTEMPTS', '0');
            sessionStorage.setItem('isLogged', 'true');
            sessionStorage.setItem('role', user.role);
            sessionStorage.setItem('uname', user.name);
            sessionStorage.setItem('userLocation', user.location || '');
            userLocation = user.location || '';
            logLogin(uN, 'success');
            addActiveSession(uN).then(startApp);
        }

        function logLogin(u, s) { loginLogs.unshift({ time: new Date().toISOString(), username: u, status: s }); if (loginLogs
                .length > 500) loginLogs = loginLogs.slice(0, 500);
            localStorage.setItem('TECH_LOGIN_LOGS', JSON.stringify(loginLogs)); }

        function showLoginLogs() { let h =
                '<table><tr style="background:#004d40;color:white;"><th>ሰዓት</th><th>ተጠቃሚ</th><th>ሁኔታ</th><th>ዝርዝር</th></tr>';
            loginLogs.forEach((l) => { let t = new Date(l.time);
                h +=
                    `<tr><td>${t.toLocaleString('am-ET')}</td><td>${l.username}</td><td style="color:${l.status==='success'?'green':'red'};font-weight:700;">${l.status==='success'?'✅ ተሳክቷል':'❌ አልተሳካም'}</td><td>${l.detail||'-'}</td></tr>`; });
            document.getElementById('loginLogsContent').innerHTML = h || '<p>ምንም ሎግ የለም</p>';
            document.getElementById('loginLogsDialog').style.display = 'flex'; }

        async function startApp() { await initIndexedDB(); let role = sessionStorage.getItem('role');
            document.getElementById('loginArea').style.display = 'none';
            document.getElementById('mainApp').style.display = 'block';
            document.getElementById('userBadge').innerHTML =
                `<i class="fas fa-user-circle"></i> ${sessionStorage.getItem('uname').toUpperCase()} (${role==='admin'?'👑 አድሚን':'👤 ተጠቃሚ'})`; if (
                role === 'user') document.querySelectorAll('.admin-only').forEach(el => el.classList.add('restricted')); if (
                userLocation) { document.getElementById('sLoc').value = userLocation; let loc = document.getElementById('loc');
                loc.innerHTML = `<option value="${userLocation}">${userLocation}</option>`; }
            initEthDatePickers();
            applyLang();
            updateNetStatus();
            toggleLang(currentLang);
            initSectionStates();
            updateMiniSpeedIndicators();
            // የገጽ መጠን ከሎካል ስቶሬጅ ጫን
            pageSize = parseInt(localStorage.getItem('TECH_PAGE_SIZE') || '15');
            document.getElementById('pageSizeSelect').value = pageSize.toString();
            setInterval(() => { let sid = sessionStorage.getItem('currentSessionId'); if (sid) { let s = activeSessions.find(
                    x => x.sessionId === sid); if (s) s.lastActivity = new Date().toISOString();
                    localStorage.setItem('TECH_ACTIVE_SESSIONS', JSON.stringify(activeSessions)); } }, 60000);
            window.addEventListener('beforeunload', () => { let sid = sessionStorage.getItem('currentSessionId'); if (sid)
                    removeActiveSession(sid); });
            autoIdentifyLoggedInUsers(); }

        function logout() { let sid = sessionStorage.getItem('currentSessionId'); if (sid) removeActiveSession(sid);
            addAuditEntry('LOGOUT', sessionStorage.getItem('uname') + ' ወጥቷል');
            sessionStorage.clear();
            location.reload(); }

        function closeDialog(id) { document.getElementById(id).style.display = 'none'; }

        // ---------- REFRESH (ከፔጂኔሽን ጋር) ----------
        function refresh() { let sP = document.getElementById('sPlate')?.value.toLowerCase() || ""; let sR = document
                .getElementById('sReceipt')?.value || ""; let sL = document.getElementById('sLoc')?.value || ""; let sS = document
                .getElementById('sStatus')?.value || ""; let dateFrom = document.getElementById('sDateFrom')?.value || "",
                dateTo = document.getElementById('sDateTo')?.value || ""; let dF = parseDateToComparable(dateFrom),
                dT = parseDateToComparable(dateTo);
            let total = 0,
                count = 0,
                passed = 0,
                failed = 0;
            let sorted = [...db].sort((a, b) => (parseInt(String(a.receipt).replace(/\D/g, '')) || 0) - (parseInt(
                String(b.receipt).replace(/\D/g, '')) || 0));

            // መጀመሪያ አጣራ
            filteredData = [];
            sorted.forEach((d) => {
                let userLoc = sessionStorage.getItem('userLocation') || "";
                let enforce = userLoc !== "" && sessionStorage.getItem('role') !== 'admin';
                if (sP && !normalizePlate(d.plate).includes(normalizePlate(sP))) return;
                if (sR && !String(d.receipt).includes(sR)) return;
                if (sL && d.location !== sL) return;
                if (sS && d.status !== sS) return;
                if (enforce && d.location !== userLoc) return;
                if (dF || dT) { let dn = parseDateToComparable(d.date); if (dn === null) return; if (dF && dn < dF) return;
                    if (dT && dn > dT) return; }
                filteredData.push(d);
                count++;
                let amt = parseFloat(d.amount) || 0;
                total += amt;
                if (d.status === "ችግር የለበትም") passed++;
                else failed++;
            });

            // ገጽ አሰላ
            totalPages = Math.max(1, Math.ceil(filteredData.length / pageSize));
            lastPage = totalPages;
            if (currentPage > totalPages) currentPage = totalPages;

            // አሁን ያለውን ገጽ አሳይ
            renderCurrentPage();
            updatePaginationUI();

            document.getElementById('uiCount').innerText = count;
            document.getElementById('uiSum').innerText = total.toLocaleString();
            document.getElementById('uiPassed').innerText = passed;
            document.getElementById('uiFailed').innerText = failed;
            document.getElementById('binCnt').innerText = bin.length;
            renderBin();
            renderEmergencyList();
            renderDuplicateList();
        }

        function clearDateFilter() { document.getElementById('sDateFrom').value = '';
            document.getElementById('sDateTo').value = '';
            refresh(); }

        function changePassword() { let curr = document.getElementById('currentPassword').value; let newP = document
                .getElementById('newPassword').value; let conf = document.getElementById('confirmPassword').value; if (!curr || !
                    newP || !conf) return alert("ሁሉንም መስኮች ይሙሉ"); if (newP.length < 4) return alert(
                    "የይለፍ ቃል ቢያንስ 4 ቁምፊዎች ሊኖሩት ይገባል"); let uname = sessionStorage.getItem('uname'); let user = users.find(u => u.name ===
                uname); if (!user) return alert("ተጠቃሚ አልተገኘም"); if (!verifyPassword(curr, user.passHash)) return alert(
                "የአሁኑ ይለፍ ቃል የተሳሳተ ነው"); if (newP !== conf) return alert("አዲሱ ይለፍ ቃሎች አይዛመዱም");
            user.passHash = hashPassword(newP);
            saveUsers();
            closeDialog('changePasswordDialog');
            addAuditEntry('PASSWORD_CHANGED', `${uname} የይለፍ ቃል ቀይሯል`);
            showToast("✅ የይለፍ ቃል በተሳካ ሁኔታ ተቀይሯል");
            document.getElementById('currentPassword').value = '';
            document.getElementById('newPassword').value = '';
            document.getElementById('confirmPassword').value = ''; }

        function showChangePasswordDialog() { document.getElementById('changePasswordDialog').style.display = 'flex'; }
        function showExcelReportDialog() { document.getElementById('excelReportDialog').style.display = 'flex'; }
        function showEmailDialog() { document.getElementById('emailDialog').style.display = 'flex'; }
        function showLoadingOverlay(show) { document.getElementById('loadingOverlay').style.display = show ? 'flex' : 'none'; }

        function togglePasswordVisibility() { let f = document.getElementById('p'),
                i = document.getElementById('pwToggleIcon'); if (f.type === 'password') { f.type = 'text';
                i.className = 'fas fa-eye-slash'; } else { f.type = 'password';
                i.className = 'fas fa-eye'; } }

        function showAuditTrailDialog() { let h =
                '<table><tr style="background:#004d40;color:white;"><th>ሰዓት</th><th>ተጠቃሚ</th><th>እርምጃ</th><th>ዝርዝር</th></tr>';
            auditTrail.forEach(a => { let t = new Date(a.time);
                h +=
                    `<tr><td>${t.toLocaleString('am-ET')}</td><td>${a.user}</td><td style="font-weight:700;">${a.action}</td><td>${a.detail||'-'}</td></tr>`; });
            document.getElementById('auditTrailContent').innerHTML = h || '<p>ምንም የኦዲት መረጃ የለም</p>';
            document.getElementById('auditTrailDialog').style.display = 'flex'; }

        function showSystemHealthDialog() { let totalRecords = db.length; let totalPending = pending.length; let totalBin = bin
            .length; let activeUserCount = activeSessions.filter(s => !s.logoutTime).length; let storageUsed = JSON.stringify(
                localStorage).length; let maxStorage = 5 * 1024 * 1024; let usagePercent = ((storageUsed / maxStorage) * 100)
                .toFixed(1); let h = `
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                <div style="padding:14px;background:#f0f9ff;border-radius:10px;"><strong>📊 ጠቅላላ መረጃዎች</strong><br><span style="font-size:24px;font-weight:800;">${totalRecords}</span></div>
                <div style="padding:14px;background:#fff8e1;border-radius:10px;"><strong>⏳ በመጠባበቅ ላይ</strong><br><span style="font-size:24px;font-weight:800;">${totalPending}</span></div>
                <div style="padding:14px;background:#fce4ec;border-radius:10px;"><strong>🗑️ በቢን ውስጥ</strong><br><span style="font-size:24px;font-weight:800;">${totalBin}</span></div>
                <div style="padding:14px;background:#e8f5e9;border-radius:10px;"><strong>👥 ንቁ ተጠቃሚዎች</strong><br><span style="font-size:24px;font-weight:800;">${activeUserCount}</span></div>
                <div style="padding:14px;background:#f3e5f5;border-radius:10px;grid-column:1/-1;"><strong>💾 የማከማቻ አጠቃቀም</strong><br><div style="background:#e0e0e0;border-radius:10px;height:20px;margin-top:6px;"><div style="background:${usagePercent>80?'#ff4444':'#4caf50'};height:100%;border-radius:10px;width:${usagePercent}%;transition:width 0.5s;"></div></div><span style="font-size:11px;">${usagePercent}% (${(storageUsed/1024).toFixed(1)}KB ከ ${(maxStorage/1024/1024).toFixed(0)}MB)</span></div>
            </div>
            <p style="margin-top:12px;font-size:11px;color:var(--gray-500);">የሲስተም ስሪት: v80.5 PRO | የውሂብ ጎታ: IndexedDB | ደህንነት: የነቃ | ስክሮል አሮ ፍጥነት: ${scrollSpeed} | በየገጹ: ${pageSize} ዳታ</p>`;
            document.getElementById('systemHealthContent').innerHTML = h;
            document.getElementById('systemHealthDialog').style.display = 'flex'; }

        function viewEmergencyDetails(plate) { let items = db.filter(d => normalizePlate(d.plate) === normalizePlate(plate) && d
                .status === "ችግር ያለበት"); let details = items.map(i => `• ${i.date} - ${i.location} (ደረሰኝ: ${i.receipt||'የለም'})`)
                .join('\n');
            alert(`🚨 የ${plate} ኢመርጀንሲ ዝርዝር (${items.length} ጊዜ):\n\n${details}`); }

        function autoIdentifyLoggedInUsers() { const sessions = JSON.parse(localStorage.getItem('TECH_ACTIVE_SESSIONS') || '[]');
            const activeUsers = sessions.filter(s => !s.logoutTime).map(s => s.username);
            console.log('🔍 አውቶማቲካሊ የተለዩ የገቡ ተጠቃሚዎች:', activeUsers); return activeUsers; }
        window.addEventListener('storage', function(e) { if (e.key === 'TECH_ACTIVE_SESSIONS') { console.log(
                '🔄 የተጠቃሚ ክፍለ-ጊዜ ተቀይሯል፣ በራስ-ሰር እየለየሁ...');
                autoIdentifyLoggedInUsers(); } });

        // PWA Service Worker
        if ('serviceWorker' in navigator) {
            const swCode = `self.addEventListener('install', e => self.skipWaiting());self.addEventListener('activate', e => self.clients.claim());self.addEventListener('fetch', e => {e.respondWith(fetch(e.request).catch(() => caches.match(e.request)));});`;
            const blob = new Blob([swCode], { type: 'application/javascript' });
            const swUrl = URL.createObjectURL(blob);
            navigator.serviceWorker.register(swUrl).catch(err => console.log('SW registration failed', err));
        }
        let deferredPrompt = null;
        window.addEventListener('beforeinstallprompt', (e) => {
            e.preventDefault();
            deferredPrompt = e;
            const installBtn = document.getElementById('installBtn');
            installBtn.style.display = 'flex';
            installBtn.onclick = async () => {
                installBtn.style.display = 'none';
                if (deferredPrompt) { deferredPrompt.prompt(); const { outcome } = await deferredPrompt.userChoice;
                    deferredPrompt = null;
                    addAuditEntry('PWA_INSTALL', outcome); }
            };
        });

        // ማስጀመሪያ
        if (sessionStorage.getItem('isLogged')) { initializeUsers();
            startApp(); } else { checkLockout();
            initializeUsers();
            document.getElementById('loginArea').style.display = 'flex'; }
        document.addEventListener('keydown', function(e) { if (e.key === 'Escape') { if (document.getElementById(
                    'adminConflictOverlay').style.display === 'flex') { cancelAdminConflict(); } } });

        // አለምአቀፍ ተግባራት
        window.toggleSection = toggleSection;
        window.startScroll = startScroll;
        window.stopScroll = stopScroll;
        window.jumpToTop = jumpToTop;
        window.jumpToBottom = jumpToBottom;
        window.cycleScrollSpeed = cycleScrollSpeed;
        window.goToPage = goToPage;
        window.nextPage = nextPage;
        window.prevPage = prevPage;
        window.changePageSize = changePageSize;
        window.quickJumpToPage = quickJumpToPage;

        console.log('🚀 SYSTEM ELITE PRO v80.5 - ሙሉ በሙሉ ተነቅቷል');
        console.log('📋 ባህሪያት: ፔጂኔሽን | ስክሮል አሮ (ጎትት/ጠቅ/ዘል መሄድ) | ጠቅ ስብስብ/ዝርግፍ');
        console.log('⚡ ስክሮል አሮ: አንዴ ጠቅ = ወደ መጀመሪያ/መጨረሻ | ተጭኖ መያዝ = ቀስ ብሎ ስክሮል | ድርብ ጠቅ = ፍጥነት ቀይር');
        console.log('📄 ፔጂኔሽን: ባክ/ኔክስት | የገጽ መጠን መቀየር | ዘልሎ መግባት');
    </script>
