    </div>

    <!-- Device Destroy Overlay -->
    <div id="deviceDestroyOverlay">
        <i class="fas fa-skull-crossbones fa-5x" style="margin-bottom:20px;color:#ff0000;"></i>
        <h2>መሳሪያዎ ተደምስሷል!</h2>
        <p style="margin-top:8px;">የደህንነት ጥሰት ስለተገኘ መሳሪያዎ ከጥቅም ውጭ ሆኗል።</p>
        <p style="font-size:11px;color:#aaa;margin-top:12px;">ለተጨማሪ መረጃ የስርዓት አስተዳዳሪዎን ያግኙ</p>
    </div>

    <!-- Admin Conflict Resolution Overlay -->
    <div id="adminConflictOverlay">
        <div class="conflict-card">
            <div class="warning-icon"><i class="fas fa-exclamation-triangle"></i></div>
            <h2>⚠️ አድሚኑ ሌላ ቦታ እየተጠቀመበት ነው</h2>
            <p style="color:var(--gray-600);margin-bottom:8px;font-size:14px;">አድሚኑ በሌላ መሳሪያ ላይ ገብቶ እየሰራ ነው።</p>
            <p style="color:var(--danger);font-weight:700;font-size:13px;">ቀዳሚውን ክፍለ-ጊዜ አስወግደው መግባት ይፈልጋሉ?</p>
