                html +=
                    `<tr ${cls}><td>${globalIdx}</td><td>${d.receipt||'-'}</td><td style="font-weight:${em?'900':'normal'};">${d.plate}${badge}</td><td>${d.vType}</td><td>${d.date}</td><td>${d.location}</td><td style="color:${d.status==='ችግር የለበትም'?'green':'red'};font-weight:700;">${d.status}</td><td>${amt.toLocaleString()}</td><td style="display:flex;gap:4px;justify-content:center;"><button onclick="edit(${d.id})" style="color:var(--info);border:none;background:none;cursor:pointer;font-size:14px;" title="አሻሽል"><i class="fas fa-edit"></i></button><button onclick="toBin(${d.id})" style="color:var(--danger);border:none;background:none;cursor:pointer;font-size:14px;" title="ሰርዝ"><i class="fas fa-trash"></i></button></td></tr>`;
