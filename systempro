                    <i class="fas fa-check"></i> አዎ፣ አስወግጄ ልግባ
                </button>
                <button class="btn-action" style="background:var(--gray-300);color:var(--gray-700);flex:1;" onclick="cancelAdminConflict()">
                    <i class="fas fa-times"></i> አይ፣ ይቅር
                </button>
