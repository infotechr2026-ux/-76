                    toggleIcon.classList.remove('expanded-icon');
                    toggleIcon.classList.add('collapsed-icon');
                    toggleIcon.querySelector('i').className = 'fas fa-chevron-down';
                }
                localStorage.setItem('TECH_SECTION_' + sectionId, 'collapsed');
            }
        }

        function initSectionStates() {
            const sections = ['searchSection', 'inputFormContent', 'tableSection'];
            sections.forEach(sectionId => {
                const savedState = localStorage.getItem('TECH_SECTION_' + sectionId);
