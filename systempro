    <style>
        :root {
            --primary: #004d40;
            --primary-light: #00695c;
            --secondary: #00796b;
            --accent: #ffb300;
            --accent-dark: #ff8f00;
            --danger: #d32f2f;
            --danger-light: #ff1744;
            --success: #00c853;
            --success-dark: #00a844;
            --info: #0288d1;
            --info-light: #03a9f4;
            --warning: #ff9800;
            --light: #f8fafc;
            --dark: #1e293b;
            --gray-50: #f9fafb;
            --gray-100: #f1f5f9;
            --gray-200: #e2e8f0;
            --gray-300: #cbd5e1;
            --gray-400: #94a3b8;
            --gray-500: #64748b;
            --gray-600: #475569;
            --gray-700: #334155;
            --gray-800: #1e293b;
            --gray-900: #0f172a;
            --glass: rgba(255, 255, 255, 0.97);
            --glass-dark: rgba(255, 255, 255, 0.92);
            --card-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
            --card-shadow-lg: 0 12px 48px rgba(0, 0, 0, 0.12);
            --card-shadow-xl: 0 20px 60px rgba(0, 0, 0, 0.18);
            --transition-fast: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            --transition-slow: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            --radius-sm: 8px;
            --radius: 12px;
            --radius-lg: 16px;
            --radius-xl: 20px;
            --radius-2xl: 28px;
            --emergency: #ff0000;
            --duplicate: #2196F3;
            --pending: #ff9800;
            --verified: #4caf50;
            --font-mono: 'SF Mono', 'Cascadia Code', 'Consolas', monospace;
            --page-size: 15;
        }
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        body {
            font-family: 'Segoe UI', 'Nyala', 'Roboto', 'Helvetica Neue', sans-serif;
            background: linear-gradient(135deg, #e8edf5 0%, #eef2f7 30%, #f8fafc 60%, #eef2f7 100%);
            background-attachment: fixed;
            margin: 0;
            color: var(--dark);
            overflow-x: hidden;
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(16px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        @keyframes slideInRight {
            from { opacity: 0; transform: translateX(30px); }
            to { opacity: 1; transform: translateX(0); }
        }
        @keyframes pulse-green {
            0% { box-shadow: 0 0 0 0 rgba(0, 200, 83, 0.7); }
            70% { box-shadow: 0 0 0 12px rgba(0, 200, 83, 0); }
            100% { box-shadow: 0 0 0 0 rgba(0, 200, 83, 0); }
        }
        @keyframes pulse-red {
            0% { box-shadow: 0 0 0 0 rgba(255, 23, 68, 0.7); }
            70% { box-shadow: 0 0 0 12px rgba(255, 23, 68, 0); }
            100% { box-shadow: 0 0 0 0 rgba(255, 23, 68, 0); }
        }
        @keyframes emergencyBlink {
            0%, 100% { background: #ff0000; color: white; }
            50% { background: #ff4444; color: white; }
        }
        @keyframes emergencyGlow {
            0%, 100% { box-shadow: 0 0 6px #ff0000, 0 0 12px rgba(255, 0, 0, 0.3); }
            50% { box-shadow: 0 0 18px #ff0000, 0 0 30px rgba(255, 0, 0, 0.5); }
        }
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            10%, 90% { transform: translateX(-4px); }
            30%, 70% { transform: translateX(4px); }
            50% { transform: translateX(-6px); }
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        @keyframes shimmer {
            0% { background-position: -200% center; }
            100% { background-position: 200% center; }
        }
        @keyframes bounce-arrow {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-6px); }
        }
        @keyframes bounce-arrow-down {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(6px); }
        }
        @keyframes jumpPulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(0, 200, 83, 0.5); }
            50% { box-shadow: 0 0 0 15px rgba(0, 200, 83, 0); }
        }
        .status-indicator {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 16px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 700;
            letter-spacing: 0.3px;
        }
        .online {
            background: #e8f5e9;
            color: var(--success-dark);
            border: 1.5px solid var(--success);
            animation: pulse-green 2s infinite;
        }
        .offline {
            background: #ffebee;
            color: var(--danger);
            border: 1.5px solid var(--danger-light);
            animation: pulse-red 2s infinite;
        }
        .emergency-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 3px 10px;
            border-radius: 8px;
            font-size: 11px;
            font-weight: 900;
            animation: emergencyBlink 0.8s infinite;
        }
        .duplicate-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 3px 10px;
            border-radius: 8px;
            font-size: 11px;
            font-weight: 900;
            background: var(--duplicate);
            color: white;
        }
        .pending-badge {
            background: var(--pending);
            color: #fff;
            padding: 2px 9px;
            border-radius: 10px;
            font-size: 11px;
            font-weight: 700;
        }
        .verified-badge {
            background: var(--verified);
            color: #fff;
            padding: 2px 9px;
            border-radius: 10px;
            font-size: 11px;
            font-weight: 700;
        }
        .emergency-row {
            animation: emergencyGlow 1.5s infinite;
            background: #fff5f5 !important;
        }
        .duplicate-row {
            background: #e8f4fd !important;
            border-left: 4px solid var(--duplicate);
        }
        #loginArea {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: radial-gradient(ellipse at 30% 20%, #00897b 0%, #00695c 30%, #004d40 70%, #003d33 100%);
            position: relative;
            overflow: hidden;
        }
        #loginArea::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -30%;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.04) 0%, transparent 70%);
            border-radius: 50%;
        }
        #loginArea::after {
            content: '';
            position: absolute;
            bottom: -40%;
            left: -20%;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.03) 0%, transparent 70%);
            border-radius: 50%;
        }
        .login-card {
            background: var(--glass);
            padding: 44px 34px;
            border-radius: var(--radius-2xl);
            box-shadow: var(--card-shadow-xl);
            width: 100%;
            max-width: 420px;
            text-align: center;
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            animation: fadeInUp 0.7s ease-out;
            position: relative;
            z-index: 1;
            border: 1px solid rgba(255, 255, 255, 0.3);
        }
        .login-card .logo-icon {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            color: white;
            font-size: 30px;
            box-shadow: 0 8px 25px rgba(0, 77, 64, 0.35);
        }
        .input-group {
            position: relative;
            margin-bottom: 18px;
        }
        .input-group input {
            width: 100%;
            padding: 14px 44px 14px 18px;
            border: 2px solid var(--gray-200);
            border-radius: var(--radius);
            font-size: 15px;
            transition: var(--transition);
            background: #fff;
            box-sizing: border-box;
            font-family: inherit;
            letter-spacing: 0.3px;
        }
        .input-group input:focus {
            border-color: var(--secondary);
            outline: none;
            box-shadow: 0 0 0 3px rgba(0, 121, 107, 0.1);
            background: #fafffe;
        }
        .input-group input.error {
            border-color: var(--danger);
            animation: shake 0.5s;
            background: #fffafa;
        }
        .password-toggle {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: var(--gray-400);
            background: none;
            border: none;
            padding: 6px;
            font-size: 16px;
            transition: var(--transition-fast);
            z-index: 2;
        }
        .password-toggle:hover { color: var(--gray-600); }
        input, select {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid var(--gray-200);
            border-radius: var(--radius);
            font-size: 14px;
            transition: var(--transition);
            background: white;
            box-sizing: border-box;
            font-family: inherit;
        }
        input:focus, select:focus {
            border-color: var(--secondary);
            outline: none;
            box-shadow: 0 0 0 3px rgba(0, 121, 107, 0.08);
        }
        .btn-action {
            padding: 12px 24px;
            border-radius: var(--radius);
            border: none;
            cursor: pointer;
            font-weight: 700;
            font-size: 14px;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            letter-spacing: 0.3px;
            font-family: inherit;
            white-space: nowrap;
        }
        .btn-action:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
        }
        .btn-action:active { transform: scale(0.97); box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1); }
        .btn-action:disabled { opacity: 0.5; pointer-events: none; cursor: not-allowed; }
        .container {
            display: none;
            padding: 0 16px;
            max-width: 1600px;
            margin: auto;
            animation: fadeIn 0.5s ease;
        }
        .header-card {
            background: white;
            padding: 18px 24px;
            border-radius: var(--radius-xl);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 14px;
            box-shadow: var(--card-shadow);
            margin-bottom: 20px;
            position: sticky;
            top: 16px;
            z-index: 100;
            border: 1px solid var(--gray-100);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }
        .dropdown { position: relative; display: inline-block; }
        .dropbtn {
            background: var(--primary);
            color: white;
            padding: 10px 18px;
            border-radius: var(--radius);
            border: none;
            font-weight: 700;
            cursor: pointer;
            font-size: 13px;
            letter-spacing: 0.3px;
            transition: var(--transition);
            font-family: inherit;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .dropbtn:hover {
            background: var(--primary-light);
            box-shadow: 0 4px 15px rgba(0, 77, 64, 0.3);
        }
        .dropdown-content {
            display: none;
            position: absolute;
            right: 0;
            top: 100%;
            background: #ffffff;
            min-width: 340px;
            box-shadow: var(--card-shadow-xl);
            border-radius: 0 0 var(--radius-lg) var(--radius-lg);
            padding: 12px;
            z-index: 9999;
            border: 1px solid var(--gray-200);
            max-height: 78vh;
            overflow-y: auto;
            animation: fadeInUp 0.2s ease;
        }
        .dropdown:hover .dropdown-content, .dropdown-content.show { display: block; }
        .dropdown-content button {
            width: 100%;
            text-align: left;
            padding: 9px 14px;
            border: none;
            background: none;
            cursor: pointer;
            border-radius: var(--radius-sm);
            font-weight: 600;
            margin-bottom: 3px;
            font-size: 13px;
            transition: var(--transition-fast);
            font-family: inherit;
            color: var(--gray-700);
        }
        .dropdown-content button:hover { background: var(--gray-100); color: var(--primary); padding-left: 18px; }
        .dropdown-content hr { border: none; border-top: 1px solid var(--gray-200); margin: 8px 0; }
        .card {
            background: white;
            padding: 20px;
            border-radius: var(--radius-xl);
            box-shadow: var(--card-shadow);
            margin-bottom: 18px;
            border: 1px solid var(--gray-100);
            transition: var(--transition);
        }
        .card:hover { box-shadow: var(--card-shadow-lg); }
        .table-container {
            overflow-x: auto;
            border-radius: var(--radius-lg);
            -webkit-overflow-scrolling: touch;
        }
        table { width: 100%; border-collapse: collapse; min-width: 850px; font-size: 13px; }
        th {
            background: var(--gray-100);
            padding: 14px 10px;
            color: var(--gray-600);
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            font-weight: 700;
            position: sticky;
            top: 0;
            z-index: 5;
        }
        td {
            padding: 11px 10px;
            text-align: center;
            border-bottom: 1px solid var(--gray-100);
            font-size: 13px;
            transition: var(--transition-fast);
        }
        tr:hover td { background-color: #fafcfd; }
        .grid-4 { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; }
        .stat-box {
            padding: 22px 20px;
            border-radius: var(--radius-xl);
            background: white;
            box-shadow: var(--card-shadow);
            text-align: center;
            border-bottom: 5px solid transparent;
            transition: var(--transition);
            cursor: default;
        }
        .stat-box:hover { transform: translateY(-3px); box-shadow: var(--card-shadow-lg); }
        .stat-box:nth-child(1) { border-bottom-color: var(--info); }
        .stat-box:nth-child(2) { border-bottom-color: var(--success); }
        .stat-box:nth-child(3) { border-bottom-color: var(--accent); }
        .stat-box:nth-child(4) { border-bottom-color: var(--danger); }
        .stat-val {
            display: block;
            font-size: 30px;
            font-weight: 800;
            color: var(--primary);
            margin-top: 8px;
            letter-spacing: -0.5px;
        }
        .stat-lbl {
            color: var(--gray-500);
            font-weight: 600;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        #toast {
            visibility: hidden;
            min-width: 280px;
            background: var(--gray-800);
            color: white;
            text-align: center;
            border-radius: var(--radius-lg);
            padding: 16px 20px;
            position: fixed;
            z-index: 100000;
            bottom: 30px;
            right: 30px;
            font-weight: 600;
            font-size: 14px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
            letter-spacing: 0.3px;
        }
        #toast.show { visibility: visible; animation: fadeInUp 0.4s ease forwards; }
        .admin-section {
            border: 1.5px dashed var(--gray-300);
            padding: 10px;
            border-radius: var(--radius);
            margin-top: 10px;
            background: #fafcfd;
        }
        .admin-section label {
            font-size: 10px;
            color: var(--danger);
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .restricted { opacity: 0.45; pointer-events: none; filter: grayscale(1); cursor: not-allowed; }
        .lang-btn {
            background: var(--gray-100);
            border: 1.5px solid var(--gray-200);
            padding: 7px 14px;
            border-radius: var(--radius-sm);
            cursor: pointer;
            font-weight: 700;
            font-size: 12px;
            transition: var(--transition-fast);
            font-family: inherit;
            letter-spacing: 0.3px;
        }
        .lang-btn:hover { background: var(--primary); color: white; border-color: var(--primary); }
        .lang-btn.active-lang { background: var(--primary); color: white; border-color: var(--primary); }
        #binDisplay, #emergencyDisplay, #duplicateDisplay {
            display: none;
            background: #fff;
            border-radius: var(--radius-xl);
            padding: 20px;
            margin-bottom: 20px;
            box-shadow: var(--card-shadow);
            animation: fadeInUp 0.35s ease;
        }
        .eth-date-picker { display: flex; gap: 5px; align-items: center; flex-wrap: wrap; }
        .eth-date-picker select, .eth-date-picker input { width: auto; min-width: 55px; padding: 8px; font-size: 13px; border-radius: var(--radius-sm); }
        .calendar-toggle { display: flex; gap: 4px; margin-bottom: 6px; }
        .calendar-toggle button {
            padding: 5px 12px;
            border: 2px solid var(--gray-200);
            border-radius: var(--radius-sm);
            background: white;
            cursor: pointer;
            font-weight: 700;
            font-size: 11px;
            transition: var(--transition-fast);
            font-family: inherit;
        }
        .calendar-toggle button.active { background: var(--primary); color: white; border-color: var(--primary); }
        .date-range-filter { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
        .date-range-filter input { width: 130px; padding: 9px; border-radius: var(--radius-sm); }
        #loadingOverlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.65);
            z-index: 999999;
            justify-content: center;
            align-items: center;
            flex-direction: column;
        }
        .spinner {
            width: 48px;
            height: 48px;
            border: 5px solid var(--gray-200);
            border-top: 5px solid var(--primary);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin: 0 auto 18px;
        }
        .install-btn {
            position: fixed;
            bottom: 100px;
            left: 20px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 40px;
            padding: 12px 20px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
            z-index: 1100;
            display: none;
            align-items: center;
            gap: 8px;
            transition: var(--transition);
            font-family: inherit;
            letter-spacing: 0.3px;
        }
        .install-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3); }
        #lockoutOverlay, #deviceDestroyOverlay, #adminConflictOverlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.9);
            z-index: 9999999;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            color: white;
            text-align: center;
        }
        #adminConflictOverlay .conflict-card {
            background: white;
            padding: 35px 30px;
            border-radius: var(--radius-2xl);
            max-width: 440px;
            text-align: center;
            color: var(--dark);
            box-shadow: var(--card-shadow-xl);
            animation: fadeInUp 0.5s ease;
        }
        #adminConflictOverlay .conflict-card h2 { color: var(--danger); margin-bottom: 10px; font-size: 20px; }
        #adminConflictOverlay .conflict-card .warning-icon { font-size: 50px; color: var(--warning); margin-bottom: 15px; animation: pulse-red 2s infinite; }
        #adminConflictOverlay .secret-input {
            width: 100%;
            padding: 14px 18px;
            border: 2px solid var(--gray-300);
            border-radius: var(--radius);
            font-size: 18px;
            text-align: center;
            letter-spacing: 6px;
            font-family: var(--font-mono);
            margin: 12px 0;
            transition: var(--transition);
            -webkit-text-security: disc;
        }
        #adminConflictOverlay .secret-input:focus { border-color: var(--secondary); box-shadow: 0 0 0 3px rgba(0, 121, 107, 0.1); }
        .dialog-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.6);
            z-index: 99999;
            justify-content: center;
            align-items: flex-start;
            padding-top: 30px;
            overflow-y: auto;
        }
        .dialog-overlay .dialog-card {
            background: white;
            max-width: 1000px;
            width: 95%;
            margin: 20px auto;
            padding: 28px;
            border-radius: var(--radius-xl);
            max-height: 88vh;
            overflow-y: auto;
            box-shadow: var(--card-shadow-xl);
            animation: fadeInUp 0.4s ease;
        }
        .dialog-overlay .dialog-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 18px;
            border-bottom: 2px solid var(--gray-100);
            padding-bottom: 14px;
        }
        .dialog-overlay .dialog-header h2 { font-size: 18px; color: var(--primary); display: flex; align-items: center; gap: 8px; }
        .dialog-overlay .close-btn { font-size: 28px; border: none; background: none; cursor: pointer; color: var(--gray-400); transition: var(--transition-fast); padding: 4px 8px; border-radius: 50%; }
        .dialog-overlay .close-btn:hover { color: var(--danger); background: var(--gray-100); }

        /* ==================== ስክሮል አሮ ቀስቶች (Scroll Arrows) ==================== */
        .scroll-arrow-container {
            position: fixed;
            right: 20px;
            bottom: 50%;
            transform: translateY(50%);
            display: flex;
            flex-direction: column;
            gap: 12px;
            z-index: 9997;
        }
        .scroll-arrow-btn {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            border: 2px solid var(--primary);
            background: white;
            color: var(--primary);
            cursor: pointer;
            font-size: 22px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--transition);
            box-shadow: var(--card-shadow-lg);
            position: relative;
            user-select: none;
            -webkit-user-select: none;
            -webkit-tap-highlight-color: transparent;
            outline: none;
        }
        .scroll-arrow-btn:hover { background: var(--primary); color: white; transform: scale(1.1); box-shadow: var(--card-shadow-xl); }
        .scroll-arrow-btn:active { transform: scale(0.95); background: var(--primary-light); }
        .scroll-arrow-btn.scroll-up { animation: bounce-arrow 1.5s infinite; }
        .scroll-arrow-btn.scroll-down { animation: bounce-arrow-down 1.5s infinite; }
        .scroll-arrow-btn.scrolling { background: var(--primary); color: white; }
        .scroll-arrow-btn .scroll-speed-indicator-mini {
            position: absolute;
            top: -8px;
            right: -8px;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            font-size: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 900;
            border: 2px solid white;
        }
        .scroll-arrow-btn .jump-indicator {
            position: absolute;
            bottom: -6px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 9px;
            background: var(--primary);
            color: white;
            padding: 1px 6px;
            border-radius: 10px;
            font-weight: 700;
            white-space: nowrap;
        }
        .speed-fast-mini { background: #e53935; }
        .speed-slow-mini { background: #1e88e5; }
        .speed-normal-mini { background: #4caf50; }

        /* ==================== ፔጂኔሽን (Pagination) ==================== */
        .pagination-container {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 16px 10px;
            flex-wrap: wrap;
            background: #f8fafc;
            border-radius: var(--radius-lg);
            margin-top: 12px;
            border: 1px solid var(--gray-200);
        }
        .pagination-container .page-btn {
            padding: 10px 16px;
            border-radius: 25px;
            border: 2px solid var(--gray-300);
            background: white;
            cursor: pointer;
            font-weight: 700;
            font-size: 13px;
            transition: var(--transition);
            font-family: inherit;
            color: var(--gray-700);
            min-width: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 4px;
            white-space: nowrap;
        }
        .pagination-container .page-btn:hover {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }
        .pagination-container .page-btn.active-page {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
            box-shadow: 0 4px 15px rgba(0, 77, 64, 0.3);
        }
        .pagination-container .page-btn:disabled {
            opacity: 0.4;
            pointer-events: none;
            cursor: not-allowed;
        }
        .pagination-container .page-info {
            font-weight: 700;
            font-size: 13px;
            color: var(--gray-600);
            padding: 0 8px;
            white-space: nowrap;
        }
        .pagination-container .page-size-select {
            width: auto;
            min-width: 70px;
            padding: 8px 12px;
            border-radius: 20px;
            border: 2px solid var(--gray-300);
            font-size: 12px;
            font-weight: 700;
            background: white;
            cursor: pointer;
            font-family: inherit;
        }
        .pagination-container .page-size-label {
            font-size: 11px;
            color: var(--gray-500);
            font-weight: 600;
            white-space: nowrap;
        }
        .pagination-quick-jump {
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .pagination-quick-jump input {
            width: 55px;
            padding: 8px;
            border-radius: 20px;
            border: 2px solid var(--gray-300);
            font-size: 13px;
            font-weight: 700;
            text-align: center;
            font-family: inherit;
        }

        /* ==================== ጠቅ ስብስብ/ዝርግፍ ==================== */
        .section-toggle-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            cursor: pointer;
            user-select: none;
            -webkit-user-select: none;
            padding: 8px 0;
        }
        .section-toggle-header .toggle-icon-btn {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: 2px solid var(--gray-300);
            background: white;
            cursor: pointer;
            font-size: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--transition);
            color: var(--gray-600);
            flex-shrink: 0;
        }
        .section-toggle-header .toggle-icon-btn:hover { background: var(--primary); color: white; border-color: var(--primary); }
        .section-toggle-header .toggle-icon-btn.collapsed-icon { transform: rotate(-90deg); }
        .section-toggle-header .toggle-icon-btn.expanded-icon { transform: rotate(0deg); }
        .collapsible-section {
            overflow: hidden;
            transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
            max-height: 3000px;
            opacity: 1;
        }
        .collapsible-section.collapsed-section { max-height: 0; opacity: 0; margin: 0; padding-top: 0; padding-bottom: 0; }
        .card.with-toggle { padding-top: 12px; }
        .card.with-toggle .card-title { margin: 0 0 8px 0; font-size: 14px; color: var(--primary); font-weight: 700; display: flex; align-items: center; gap: 8px; }

        @media (max-width: 768px) {
            .grid-4 { grid-template-columns: 1fr 1fr; }
            .header-card { flex-direction: column; text-align: center; padding: 14px 16px; }
            .stat-val { font-size: 24px; }
            .btn-action { padding: 10px 16px; font-size: 12px; }
            .login-card { padding: 30px 20px; margin: 0 12px; }
            .dropdown-content { min-width: 280px; right: -40px; }
            table { min-width: 650px; font-size: 11px; }
            th, td { padding: 8px 6px; }
            .scroll-arrow-container { right: 8px; gap: 8px; }
            .scroll-arrow-btn { width: 40px; height: 40px; font-size: 18px; }
            .pagination-container { gap: 4px; padding: 10px 6px; }
            .pagination-container .page-btn { padding: 8px 10px; font-size: 11px; min-width: 32px; }
        }
        @media (max-width: 400px) {
            .grid-4 { grid-template-columns: 1fr; }
            .stat-val { font-size: 20px; }
            .scroll-arrow-container { right: 4px; bottom: 40%; }
            .scroll-arrow-btn { width: 36px; height: 36px; font-size: 16px; }
            .pagination-container .page-btn { padding: 6px 8px; font-size: 10px; min-width: 28px; }
        }
    </style>
</head>
<body>
    <!-- ==================== ስክሮል አሮ (Scroll Arrows) ==================== -->
    <div class="scroll-arrow-container" id="scrollArrowContainer">
        <button class="scroll-arrow-btn scroll-up" id="btnScrollUp" title="አንዴ ጠቅ = ወደላይ መጀመሪያ | ተጭነው ይያዙ = ቀስ ብሎ ስክሮል | ድርብ ጠቅ = ፍጥነት ቀይር"
                onclick="jumpToTop()" 
                onmousedown="startScroll('up', event)" onmouseup="stopScroll()" onmouseleave="stopScroll()"
                ontouchstart="startScroll('up', event)" ontouchend="stopScroll()" ontouchcancel="stopScroll()">
            <i class="fas fa-chevron-up"></i>
            <span class="scroll-speed-indicator-mini speed-normal-mini" id="miniSpeedUp">1x</span>
            <span class="jump-indicator" style="font-size:7px;">⏫ መጀመሪያ</span>
        </button>
        <button class="scroll-arrow-btn scroll-down" id="btnScrollDown" title="አንዴ ጠቅ = ወደታች መጨረሻ | ተጭነው ይያዙ = ቀስ ብሎ ስክሮል | ድርብ ጠቅ = ፍጥነት ቀይር"
                onclick="jumpToBottom()"
                onmousedown="startScroll('down', event)" onmouseup="stopScroll()" onmouseleave="stopScroll()"
                ontouchstart="startScroll('down', event)" ontouchend="stopScroll()" ontouchcancel="stopScroll()">
            <i class="fas fa-chevron-down"></i>
            <span class="scroll-speed-indicator-mini speed-normal-mini" id="miniSpeedDown">1x</span>
            <span class="jump-indicator" style="font-size:7px;">⏬ መጨረሻ</span>
        </button>
    </div>

    <!-- Toast Notification -->
    <div id="toast">✅ መልዕክት</div>

    <!-- Loading Overlay -->
    <div id="loadingOverlay">
        <div style="background:white; padding:40px 30px; border-radius:20px; text-align:center;">
            <div class="spinner"></div>
            <h3 style="color:var(--primary);">እየተከናወነ ነው...</h3>
            <p style="color:var(--gray-500); font-size:13px;">እባክዎ ይጠብቁ</p>
        </div>
    </div>

    <!-- PWA Install Button -->
    <button id="installBtn" class="install-btn" style="display:none;"><i class="fas fa-download"></i> Install App</button>

    <!-- Lockout Overlay -->
    <div id="lockoutOverlay">
        <i class="fas fa-lock fa-5x" style="margin-bottom:20px;color:#ff4444;"></i>
        <h2>ሲስተሙ ተቆልፏል</h2>
        <p style="margin-top:8px;">እባክዎ <span id="lockoutTimer" style="font-weight:bold;font-size:2.5em;color:#ffb300;">120</span> ሰከንድ ይጠብቁ</p>
