            // የገጽ መጠን ማሳያ አዘምን
            document.getElementById('pageSizeSelect').value = pageSize.toString();
        }

        function goToPage(page) {
            if (page < 1 || page > totalPages) return;
            currentPage = page;
            renderCurrentPage();
            updatePaginationUI();
            // ወደ ሰንጠረዡ አናት ስክሮል አድርግ
            document.getElementById('tableCardWrapper').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function nextPage() {
            if (currentPage < totalPages) goToPage(currentPage + 1);
        }

        function prevPage() {
            if (currentPage > 1) goToPage(currentPage - 1);
        }

        function changePageSize() {
            pageSize = parseInt(document.getElementById('pageSizeSelect').value);
            localStorage.setItem('TECH_PAGE_SIZE', pageSize.toString());
            currentPage = 1;
            totalPages = Math.max(1, Math.ceil(filteredData.length / pageSize));
            renderCurrentPage();
            updatePaginationUI();
            showToast(`📄 በየገጹ ${pageSize} ዳታ ይታያል`);
