        function startScroll(direction, event) {
            // ነጠላ ጠቅ ከሆነ jump እንዲያደርግ onclick ተቀናብሯል
            // ተጭኖ መያዝ ከሆነ ብቻ ቀስ ብሎ ስክሮል ያደርጋል
            if (event) {
                // ጠቅ ማድረግ ብቻ ከሆነ (አጭር ጠቅ) jump ያደርጋል - onclick ይይዘዋል
                // ተጭኖ መያዝ ከሆነ ብቻ ቀስ ብሎ ስክሮል
                const isTouch = event.type.startsWith('touch');
                if (!isTouch && event.button !== 0) return; // ግራ ጠቅ ብቻ
            }

            stopScroll();
            const speedData = SCROLL_SPEEDS[scrollSpeed];
            const btn = direction === 'up' ? document.getElementById('btnScrollUp') : document.getElementById('btnScrollDown');
            if (btn) btn.classList.add('scrolling');

            // ለረጅም ጊዜ መያዝ ብቻ ቀስ ብሎ ስክሮል
            function scrollStep() {
                const amount = direction === 'up' ? -speedData.amount : speedData.amount;
                window.scrollBy(0, amount);
                scrollInterval = setTimeout(scrollStep, speedData.interval);
            }
            // ትንሽ መዘግየት ከደረሰ በኋላ ብቻ መሸብለል ይጀምራል (ለ jump ጊዜ ለመስጠት)
            scrollInterval = setTimeout(() => {
                scrollStep();
            }, 200);
        }

        function stopScroll() {
            if (scrollInterval) {
                clearTimeout(scrollInterval);
                scrollInterval = null;
            }
            const upBtn = document.getElementById('btnScrollUp');
            const downBtn = document.getElementById('btnScrollDown');
            if (upBtn) upBtn.classList.remove('scrolling');
            if (downBtn) downBtn.classList.remove('scrolling');
        }

        // አንዴ ጠቅ = ወደ መጀመሪያ ዘልሎ መሄድ
