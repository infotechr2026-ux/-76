        // ==================== ጠቅ ስብስብ/ዝርግፍ ====================
        function toggleSection(sectionId) {
            const section = document.getElementById(sectionId);
            if (!section) return;
            const isCollapsed = section.classList.contains('collapsed-section');
            let toggleIconId;
            switch (sectionId) {
                case 'searchSection': toggleIconId = 'searchToggleIcon'; break;
                case 'inputFormContent': toggleIconId = 'inputFormToggleIcon'; break;
                case 'tableSection': toggleIconId = 'tableToggleIcon'; break;
                default: toggleIconId = null;
            }
            const toggleIcon = toggleIconId ? document.getElementById(toggleIconId) : null;
            if (isCollapsed) {
                section.classList.remove('collapsed-section');
                if (toggleIcon) {
                    toggleIcon.classList.remove('collapsed-icon');
                    toggleIcon.classList.add('expanded-icon');
                    toggleIcon.querySelector('i').className = 'fas fa-chevron-up';
                }
                localStorage.setItem('TECH_SECTION_' + sectionId, 'expanded');
