        // ---------- የቀን ማስተካከያ ----------
        function normalizeDate(dateStr) { if (!dateStr) return '';
            let n = dateStr.trim(); if (n.includes('(')) n = n.split('(')[0].trim(); while (n.startsWith('/')) n = n.substring(
                1);
            n = n.replace(/ዓ\.ም/g, '').replace(/\s+/g, ' ').trim();
            let p = n.split('/'); if (p.length === 3) { let d = p[0].padStart(2, '0'); let m = p[1].padStart(2, '0'); let y = p[
                    2]; if (y.length === 2) y = '20' + y;
                else if (y.length === 3) y = '2' + y;
                else if (y.length > 4) { if (y.length === 5) y = y.substring(0, 4);
                else if (y.length === 6 && y.startsWith('0')) y = y.substring(2);
                else y = y.substring(0, 4); } let yn = parseInt(y, 10); if (yn < 1900) yn += 2000;
                else if (yn > 2100) yn = 2000 + (yn % 100);
                y = yn.toString();
                n = `${d}/${m}/${y}`; } return n.trim(); }

        function formatDisplayDate(dateStr) { if (!dateStr) return ''; let n = normalizeDate(dateStr); let p = n.split('/'); if (p
                .length !== 3) return dateStr; let d = p[0].padStart(2, '0'); let m = parseInt(p[1], 10); let y = p[2]; if (m < 1 ||
                m > 13) m = 1; let mn = ethiopianMonths[m - 1] || ""; return `${d}/${m}/${y} (${mn})`; }

        function parseDateToComparable(dateStr) { if (!dateStr) return null; try { let c = normalizeDate(dateStr); let p = c.split(
                '/'); if (p.length !== 3) return null; let d = parseInt(p[0], 10),
                m = parseInt(p[1], 10), y = parseInt(p[2], 10); if (isNaN(d) || isNaN(m) || isNaN(y)) return null; return y *
                10000 + m * 100 + d; } catch (e) { return null; } }

        function normalizeCloudDataDates(cloudData) { if (!Array.isArray(cloudData)) return cloudData; return cloudData.map(
            item => { if (item.date) item.date = formatDisplayDate(normalizeDate(item.date)); return item; }); }

        // ---------- ኢትዮጵያ ካላንደር ----------
        function isEthLeapYear(y) { return (y % 4) === 3; }
        function getEthMonthDays(mi, y) { return mi === 12 ? (isEthLeapYear(y) ? 6 : 5) : 30; }
        function ethToJDN(d, m, y) { return 1724221 + 365 * (y - 1) + Math.floor(y / 4) + 30 * m + d - 31; }
        function jdnToGreg(jdn) { let l = jdn + 68569,
                n = Math.floor(4 * l / 146097); l -= Math.floor((146097 * n + 3) / 4); let i = Math.floor(4000 * (l + 1) /
                1461001); l = l - Math.floor(1461 * i / 4) + 31; let j = Math.floor(80 * l / 2447),
                day = l - Math.floor(2447 * j / 80); l = Math.floor(j / 11); return { year: 100 * (n - 49) + i + l, month: j + 2 -
                    12 * l, day }; }
        function ethToGreg(d, m, y) { return jdnToGreg(ethToJDN(d, m, y)); }
        function gregToJDN(y, m, d) { let a = Math.floor((14 - m) / 12),
                yr = y + 4800 - a,
                mo = m + 12 * a - 3; return d + Math.floor((153 * mo + 2) / 5) + 365 * yr + Math.floor(yr / 4) - Math.floor(yr /
                100) + Math.floor(yr / 400) - 32045; }
        function jdnToEth(jdn) { let r = (jdn - 1724221) % 1461,
                n = (r % 365) + 365 * Math.floor(r / 1460); let y = 4 * Math.floor((jdn - 1724221) / 1461) + Math.floor(r / 365) -
                Math.floor(r / 1460); let m = Math.floor(n / 30) + 1,
                d = (n % 30) + 1; if (m > 13) m = 13; return { year: y, month: m, day: d }; }
        function gregToEth(gY, gM, gD) { return jdnToEth(gregToJDN(gY, gM, gD)); }
        function formatEthDate(d, mi, y) { let mn = ethMonths[mi - 1] ? ethMonths[mi - 1].name : "?"; return String(d).padStart(2,
                '0') + "/" + String(mi).padStart(2, '0') + "/" + y + " (" + mn + ")"; }
        function parseEthDateStr(ds) { if (!ds) return null; let c = ds.split('(')[0].trim(),
            p = c.split('/'); if (p.length !== 3) return null; return { day: parseInt(p[0], 10), month: parseInt(p[1], 10),
